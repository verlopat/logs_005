# ── Fabric Gateway API ───────────────────────────────────────────────
GATEWAY_BASE_URL=http://localhost:3000
GATEWAY_PORT=3000
GATEWAY_TIMEOUT=30

# ── Fabric network ───────────────────────────────────────────────────
FABRIC_CHANNEL=securitylogchannel
FABRIC_CHAINCODE=security_logger
FABRIC_MSP_ID=CloudSecOrgMSP
FABRIC_PEER_ADDR=localhost:7051
# Resolved relative to server.js by default; override if crypto-config is elsewhere
# FABRIC_CRYPTO_BASE=/absolute/path/to/crypto-config/peerOrganizations/cloudsec.securitylog.com

# ── IPFS ─────────────────────────────────────────────────────────────
IPFS_API_URL=http://127.0.0.1:5001

# ── Logging ──────────────────────────────────────────────────────────
LOG_LEVEL=INFO
