# .env.example — copy to .env and adjust if needed

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Fabric ─────────────────────────────────────────────────────────────────────
FABRIC_CHANNEL=securitylogchannel
FABRIC_CHAINCODE=security_logger
FABRIC_ORG=CloudSecOrg
FABRIC_PEER=grpcs://localhost:7051
FABRIC_ORDERER=grpcs://localhost:7050
FABRIC_NET_PROFILE=blockchain/sdk/network_profile.json

# ── IPFS ───────────────────────────────────────────────────────────────────────
IPFS_API_URL=http://localhost:5001/api/v0
IPFS_GATEWAY=http://localhost:8080/ipfs
IPFS_TIMEOUT=30

# ── Agent identity (Fabric CA issued) ─────────────────────────────────────────
AGENT_PRIVATE_KEY_PATH=blockchain/network/crypto-config/peerOrganizations/cloudsec.securitylog.com/users/User1@cloudsec.securitylog.com/msp/keystore/priv_sk
AGENT_CERT_PATH=blockchain/network/crypto-config/peerOrganizations/cloudsec.securitylog.com/users/User1@cloudsec.securitylog.com/msp/signcerts/User1@cloudsec.securitylog.com-cert.pem

# ── Reports ────────────────────────────────────────────────────────────────────
REPORT_DIR=output/reports
